[{"id":"011f1323-3c5b-4f2f-863e-c069f039821f","projectId":"7b5ad97c-34bf-486e-a32d-1d5626f5de9e","documentId":"1f78fa1f-5077-4375-99f0-6703550ca2cc","type":"note","x":-295.179,"y":-231.363,"width":540.348,"height":294.713,"zIndex":12,"createdAt":1777545614611,"updatedAt":1777545646762,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Galileo vs Aristotle</h3><div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\"></th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Aristotle (Wrong)</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Galileo (Correct)</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Force needed to...</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">maintain motion</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">change motion</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Natural state</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">rest</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">constant velocity</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Objects stop because...</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">no force</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">friction acts</td></tr></tbody></table></div><p>\n\n</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Galileo's thought experiment:</strong> Ball on frictionless surface would roll forever → no force needed to maintain motion.</p>","color":"#dbeafe","sourceExcerpt":"4.2 Historical Background: Aristotle vs Galileo","sourcePageNumber":3}},{"id":"1c7df2c2-cfcf-4c49-b187-1c2eb09ddf2d","projectId":"7b5ad97c-34bf-486e-a32d-1d5626f5de9e","documentId":"1f78fa1f-5077-4375-99f0-6703550ca2cc","type":"note","x":-57.0552,"y":1475.35,"width":554.002,"height":356.608,"zIndex":41,"createdAt":1777545842407,"updatedAt":1777545858048,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Friction</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Definition:</strong> Contact force opposing relative motion (or attempted motion) between surfaces. Acts parallel to surface, opposite to motion.</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>History:</strong> Leonardo da Vinci first studied it (1493). Coulomb distinguished static vs kinetic friction (1785).</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Static Friction (fs)</strong> — object not yet moving, self-adjusting:</p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\">fs ≤ μs·N (adjusts to match applied force)</li>\n<li class=\"whitespace-normal break-words pl-2\">Maximum: <strong>fs(max) = μs·N</strong></li>\n</ul><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Kinetic Friction (fk)</strong> — object already sliding:</p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\"><strong>fk = μk·N</strong> (constant value)</li>\n<li class=\"whitespace-normal break-words pl-2\">Always: <strong>μk &lt; μs</strong> → harder to START moving than to KEEP moving</li>\n</ul><p>\n\n\n\n\n\n\n</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Example:</strong> 10 kg block, μs=0.4, μk=0.3, g=10 → N=100 N → fs(max)=40 N, fk=30 N. Applied 50 N &gt; 40 N → block moves. Net force = 50−30 = 20 N → <strong>a = 2 m/s²</strong></p></blockquote>","color":"#dbeafe","sourceExcerpt":"4.4.1 Friction","sourcePageNumber":6}},{"id":"463a1f3d-835d-4c24-86df-3524cdb9f284","projectId":"7b5ad97c-34bf-486e-a32d-1d5626f5de9e","documentId":"1f78fa1f-5077-4375-99f0-6703550ca2cc","type":"note","x":-432.222,"y":-631.111,"width":547.63,"height":271.957,"zIndex":6,"createdAt":1777545565206,"updatedAt":1777545581790,"data":{"type":"note","content":"<div><div class=\"standard-markdown grid-cols-1 grid [&amp;_&gt;_*]:min-w-0 gap-3\"><h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Force</h3></div></div><div><div class=\"standard-markdown grid-cols-1 grid [&amp;_&gt;_*]:min-w-0 gap-3\"><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Definition:</strong> Push or pull that changes state of rest/motion, speed, direction, or shape. Vector quantity. SI unit = <strong>Newton (N)</strong>. 1 N = 1 kg·m/s²</p></div></div><div><div class=\"standard-markdown grid-cols-1 grid [&amp;_&gt;_*]:min-w-0 gap-3\"><div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Contact Forces</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Non-Contact Forces</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Friction, Normal, Tension</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Gravity, Electrostatic</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Spring, Air resistance</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Magnetic, Nuclear</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Applied force (push/pull)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Act through fields, at a distance</td></tr></tbody></table></div></div></div>","color":"#dbeafe","sourceExcerpt":"4.1 The Concept of Force","sourcePageNumber":2}},{"id":"56e41e7c-e744-47bb-9240-59ff8e2caca1","projectId":"7b5ad97c-34bf-486e-a32d-1d5626f5de9e","documentId":"1f78fa1f-5077-4375-99f0-6703550ca2cc","type":"note","x":-331.032,"y":155.682,"width":645.934,"height":307.456,"zIndex":18,"createdAt":1777545676991,"updatedAt":1777545693367,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Newton's First Law — Law of Inertia</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Statement:</strong> Every object stays at rest or in uniform straight-line motion unless acted upon by an external unbalanced force.</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Inertia</strong> = resistance to change in state of motion. Mass is the measure of inertia — more mass = more inertia.</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>3 types of inertia:</strong></p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\"><strong>Inertia of rest</strong> → Passengers jerk backward when bus starts suddenly; dust flies off beaten carpet</li>\n<li class=\"whitespace-normal break-words pl-2\"><strong>Inertia of motion</strong> → Passengers jerk forward when bus brakes; athlete runs past finish line</li>\n<li class=\"whitespace-normal break-words pl-2\"><strong>Inertia of direction</strong> → Sparks fly tangentially off a grinding wheel</li>\n</ul><p>\n\n\n\n\n</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Inertial frame</strong> = frame where Newton's 1st law holds. Any frame moving at constant velocity is inertial. Accelerating frames are non-inertial.</p></blockquote>","color":"#dbeafe","sourceExcerpt":"4.3 Newton's Laws of Motion\n4.3.1 Newton's First Law — The Law of Inertia\n📘 Newton's First Law","sourcePageNumber":4}},{"id":"656293bd-2b67-4ed7-9f5a-38594d16ac7c","projectId":"7b5ad97c-34bf-486e-a32d-1d5626f5de9e","documentId":"1f78fa1f-5077-4375-99f0-6703550ca2cc","type":"note","x":-208.303,"y":2026.56,"width":604.139,"height":288.391,"zIndex":1777545898824,"createdAt":1777545898816,"updatedAt":1777545909771,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Quick-Recall Formulas</h3><p>\n</p><div role=\"group\" aria-label=\"Code\" tabindex=\"0\" class=\"relative group/copy bg-bg-000/50 border-0.5 border-border-400 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-100\"><div class=\"sticky opacity-0 group-hover/copy:opacity-100 group-focus-within/copy:opacity-100 top-2 py-2 h-12 w-0 float-right\"><div class=\"absolute right-0 h-8 px-2 items-center inline-flex z-10\"><button class=\"inline-flex\n  items-center\n  justify-center\n  relative\n  isolate\n  shrink-0\n  can-focus\n  select-none\n  disabled:pointer-events-none\n  disabled:opacity-50\n  disabled:shadow-none\n  disabled:drop-shadow-none border-transparent\n          transition\n          font-base\n          duration-300\n          ease-[cubic-bezier(0.165,0.85,0.45,1)] h-8 w-8 rounded-md backdrop-blur-md _fill_10ocf_9 _ghost_10ocf_96\" type=\"button\" aria-label=\"Copy to clipboard\" data-state=\"closed\"><div class=\"relative\"><div class=\"transition-all opacity-100 scale-100\" style=\"width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"currentColor\" xmlns=\"http://www.w3.org/2000/svg\" class=\"transition-all opacity-100 scale-100\" aria-hidden=\"true\" style=\"flex-shrink: 0;\"><path d=\"M12.5 3A1.5 1.5 0 0 1 14 4.5V6h1.5A1.5 1.5 0 0 1 17 7.5v8a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 6 15.5V14H4.5A1.5 1.5 0 0 1 3 12.5v-8A1.5 1.5 0 0 1 4.5 3zm1.5 9.5a1.5 1.5 0 0 1-1.5 1.5H7v1.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5H14zM4.5 4a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5z\"></path></svg></div><div class=\"absolute inset-0 flex items-center justify-center\"><div class=\"transition-all opacity-0 scale-50\" style=\"width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"currentColor\" xmlns=\"http://www.w3.org/2000/svg\" class=\"transition-all opacity-0 scale-50\" aria-hidden=\"true\" style=\"flex-shrink: 0;\"><path d=\"M15.188 5.11a.5.5 0 0 1 .752.626l-.056.084-7.5 9a.5.5 0 0 1-.738.033l-3.5-3.5-.064-.078a.501.501 0 0 1 .693-.693l.078.064 3.113 3.113 7.15-8.58z\"></path></svg></div></div></div></button></div></div><div class=\"overflow-x-auto\"><pre class=\"code-block__code !my-0 !rounded-lg !text-sm !leading-relaxed p-3.5\" style=\"color: rgb(234, 236, 240); background-image: initial; background-position: initial; background-size: initial; background-repeat: initial; background-attachment: initial; background-origin: initial; background-clip: initial;\"><code style=\"background: transparent; font-family: var(--font-mono); white-space: pre-wrap;\">F = ma = dp/dt            ← 2nd law\nfs(max) = μs·N            ← max static friction  \nfk = μk·N  (μk &lt; μs)     ← kinetic friction\np = mv                    ← momentum\nJ = F·Δt = Δp             ← impulse\nFc = mv²/r                ← centripetal force\ntan θ = v²/rg             ← banking angle\nN = mg cosθ (incline)     ← normal on slope\na = g sinθ (smooth incline) ← acceleration on slope\na = (m₁−m₂)g/(m₁+m₂)    ← Atwood machine</code></pre></div></div>","color":"yellow","sourceExcerpt":null,"sourcePageNumber":null}},{"id":"ba4857b3-9e09-4e6b-b81e-b21c6beac083","projectId":"7b5ad97c-34bf-486e-a32d-1d5626f5de9e","documentId":"1f78fa1f-5077-4375-99f0-6703550ca2cc","type":"note","x":-169.012,"y":568.568,"width":452.967,"height":328.391,"zIndex":26,"createdAt":1777545719178,"updatedAt":1777545751896,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Newton's Second Law — F = ma</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Statement:</strong> Rate of change of momentum is proportional to net force, in the direction of force.</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>F⃗_net = ma⃗</strong> (constant mass) | <strong>F⃗ = dp⃗/dt</strong> (general form)</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Key points:</p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\">F here is the <strong>net (resultant)</strong> force, not any single force</li>\n<li class=\"whitespace-normal break-words pl-2\">Acceleration is always in the <strong>same direction as net force</strong></li>\n<li class=\"whitespace-normal break-words pl-2\">First Law is just a special case: when F_net = 0 → a = 0 → v = constant</li>\n</ul><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Example:</strong> 20 N on 4 kg body at rest → a = 20/4 = <strong>5 m/s²</strong> → after 5s: v = 25 m/s, distance = 62.5 m</p>\n</blockquote><p>\n\n\n\n\n\n</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">⚠️ Newton originally wrote F = dp/dt. The \"F = ma\" form was formalized later by <strong>Euler</strong>.</p></blockquote>","color":"#dbeafe","sourceExcerpt":"4.3.2 Newton's Second Law — F = ma","sourcePageNumber":4}},{"id":"cabfb9d4-dcf3-49b9-847d-b8dfe95d36a5","projectId":"7b5ad97c-34bf-486e-a32d-1d5626f5de9e","documentId":"1f78fa1f-5077-4375-99f0-6703550ca2cc","type":"note","x":-357.428,"y":1003.3,"width":532.156,"height":342.044,"zIndex":35,"createdAt":1777545781609,"updatedAt":1777545807798,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Newton's Third Law — Action-Reaction</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Statement:</strong> For every action there is an equal and opposite reaction. F⃗_AB = −F⃗_BA</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>4 crucial points:</strong></p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\">Action &amp; reaction act on <strong>different bodies</strong> — they never cancel</li>\n<li class=\"whitespace-normal break-words pl-2\">They are <strong>simultaneous</strong> — neither comes first</li>\n<li class=\"whitespace-normal break-words pl-2\">Always <strong>equal in magnitude</strong>, opposite in direction</li>\n<li class=\"whitespace-normal break-words pl-2\">Always of the <strong>same type</strong> (both gravitational, both contact, etc.)</li>\n</ul><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Examples:</strong> Foot pushes ground back → ground pushes foot forward (walking). Gas pushed down → rocket pushed up. Book pushes table → table pushes book up.</p>\n</blockquote><p>\n\n\n\n\n</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">⚠️ \"If action = reaction, how does anything move?\" → Because they act on <strong>different objects</strong>. Net force on each object depends on all forces on <em>that</em> object alone.</p></blockquote>","color":"#dbeafe","sourceExcerpt":"4.3.3 Newton's Third Law — Action and Reaction\n📘 Newton's Third Law","sourcePageNumber":5}}]