[{"id":"05bdcf4f-930b-43dd-bb94-72044e881f8a","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"image","x":-560.667,"y":-671.834,"width":381.92,"height":158.644,"zIndex":1777551712501,"createdAt":1777551680831,"updatedAt":1777551693764,"data":{"type":"image","blobId":"b079050a-0708-4318-813b-228adbd3e803","name":"Page 1 excerpt","mimeType":"image/png","source":"select-area","sourcePageNumber":1,"sourceDocumentId":"d8d0e4cb-250e-497b-ad5e-604b335ee301"}},{"id":"137e2e17-1ccf-456c-a7e9-1e99059764ba","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"line","x":-389.32752003009057,"y":-558.9107428754843,"width":276.6830200300906,"height":141.13474287548428,"zIndex":1777551712500,"createdAt":1777551712500,"updatedAt":1777551713439,"data":{"type":"line","fromItemId":null,"toItemId":"e657faca-42d4-4931-99cc-de700e2d4bb9","toAnchor":"top","points":[{"x":10,"y":10},{"x":266.6830200300906,"y":131.13474287548428}],"color":"#64748b","strokeWidth":2,"style":"solid","arrowHead":false}},{"id":"1c06bc55-f8cf-40b0-ae9f-5d8086ac5750","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-399.087,"y":3393.5,"width":727.929,"height":345.735,"zIndex":1777552310912,"createdAt":1777552310905,"updatedAt":1777552321169,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Quick-Fire Must-Remembers</h3><p>\n</p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\">Heat flows hot → cold; Temperature does NOT flow</li>\n<li class=\"whitespace-normal break-words pl-2\">0 K = −273.15°C = absolute zero (lowest possible temperature, no negative Kelvin)</li>\n<li class=\"whitespace-normal break-words pl-2\">Size of 1°C = size of 1 K (just different starting points)</li>\n<li class=\"whitespace-normal break-words pl-2\">−40°C = −40°F (only point where scales are equal)</li>\n<li class=\"whitespace-normal break-words pl-2\">α : β : γ = 1 : 2 : 3 (always)</li>\n<li class=\"whitespace-normal break-words pl-2\">Water has highest specific heat among common substances</li>\n<li class=\"whitespace-normal break-words pl-2\">L_v (steam) &gt;&gt; L_f (ice) → steam burns worse than boiling water</li>\n<li class=\"whitespace-normal break-words pl-2\">During phase change → temperature stays constant, heat still being absorbed</li>\n<li class=\"whitespace-normal break-words pl-2\">Radiation is the only mode that works in vacuum (sunlight!)</li>\n<li class=\"whitespace-normal break-words pl-2\">Dark surfaces absorb and emit more; shiny surfaces reflect more</li>\n<li class=\"whitespace-normal break-words pl-2\">Newton's cooling: exponential decay; valid only for small temperature differences</li></ul>","color":"yellow","sourceExcerpt":null,"sourcePageNumber":null}},{"id":"290910ca-5c16-4cd7-b1b4-2578cc2876d9","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-360.998,"y":-427.776,"width":476.707,"height":124.551,"zIndex":1777551697154,"createdAt":1777551697148,"updatedAt":1777551709401,"data":{"type":"note","content":"<div><div class=\"standard-markdown grid-cols-1 grid [&amp;_&gt;_*]:min-w-0 gap-3\"><h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Core Concepts Overview</h3></div></div><div><div class=\"standard-markdown grid-cols-1 grid [&amp;_&gt;_*]:min-w-0 gap-3\"><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">This chapter covers how matter responds to heat — temperature measurement, gas laws, expansion, specific heat, phase changes, heat transfer, and cooling.</p></div></div>","color":"yellow","sourceExcerpt":null,"sourcePageNumber":null}},{"id":"616975aa-9b92-45ef-8dea-a6fe97a2743c","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-551.141,"y":446.885,"width":541.259,"height":282.88,"zIndex":1777551712517,"createdAt":1777551858865,"updatedAt":1777551888038,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Ideal Gas Laws</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Boyle's Law</strong> (constant T): PV = constant → P₁V₁ = P₂V₂</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Charles' Law</strong> (constant P): V/T = constant → V₁/T₁ = V₂/T₂</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Gay-Lussac's Law</strong> (constant V): P/T = constant</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Ideal Gas Equation: PV = nRT</strong></p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\">R = 8.314 J/(mol·K) — universal gas constant</li>\n<li class=\"whitespace-normal break-words pl-2\">PV = Nk_bT where k_b = 1.38 × 10⁻²³ J/K (Boltzmann constant)</li>\n<li class=\"whitespace-normal break-words pl-2\"><strong>1 mole of any ideal gas at STP occupies 22.4 litres</strong></li>\n</ul><p>\n\n\n\n\n\n</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Example: 2 moles at STP → V = 2 × 8.314 × 273 / 101300 = <strong>44.8 litres</strong></p></blockquote>","color":"#dbeafe","sourceExcerpt":"10.4 Ideal Gas Equation","sourcePageNumber":4}},{"id":"62c14ea4-4e51-4669-84a6-239b2a7a70ff","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-390.034,"y":2542.62,"width":787.019,"height":628.765,"zIndex":1777551712564,"createdAt":1777552231174,"updatedAt":1777552290234,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">&nbsp;Heat Transfer — Three Modes</h3><div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Property</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Conduction</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Convection</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Radiation</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Medium needed?</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Yes (solids mainly)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Yes (fluids)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\"><strong>No (vacuum OK)</strong></td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Material moves?</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">No</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Yes (bulk flow)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">No</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Speed</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Slow</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Moderate</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Speed of light</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Example</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Metal spoon in hot soup</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Boiling water, sea breeze</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Sunlight, campfire</td></tr></tbody></table></div><h4 class=\"text-text-100 mt-2 -mb-1 text-base font-bold\">Conduction:</h4><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Q/t = KA(T₁ − T₂)/L</strong> | K = thermal conductivity (W/m·K)</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Metals → good conductors. Wood, air → poor conductors (insulators). Winter clothes trap air → keep you warm.</p>\n</blockquote><h4 class=\"text-text-100 mt-2 -mb-1 text-base font-bold\">Convection:</h4><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Hot fluid rises (less dense) → cold fluid sinks (more dense) → circular convection currents.</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Examples: Sea breeze/land breeze, room heater placed at floor level, ventilation systems.</p>\n</blockquote><h4 class=\"text-text-100 mt-2 -mb-1 text-base font-bold\">Radiation:</h4><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>E = σAT⁴</strong> | σ = 5.67 × 10⁻⁸ W/m²K⁴ (Stefan's constant)</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Net radiation for body at T in surroundings at T₀: <strong>σA(T⁴ − T₀⁴)</strong></p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\">Dark/rough surfaces → absorb and emit MORE radiation</li>\n<li class=\"whitespace-normal break-words pl-2\">Shiny/smooth surfaces → reflect more (better for keeping cool)</li>\n<li class=\"whitespace-normal break-words pl-2\"><strong>Wien's Law:</strong> λ_max × T = constant (hotter body → peak shifts to shorter wavelength)</li>\n<li class=\"whitespace-normal break-words pl-2\"><strong>Black body</strong> = perfect absorber and emitter (ideal concept; lamp black ≈ close approximation)</li>\n</ul><p>\n\n\n\n\n\n\n\n\n\n\n\n</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-pre-wrap leading-[1.7]\">Why light clothes in summer? Reflect radiation. Why dark clothes in winter? Absorb radiation.\nThermos flask: silvered walls (reduce radiation), vacuum (stops conduction + convection), cork stopper.</p></blockquote>","color":"#dbeafe","sourceExcerpt":"10.9 Heat Transfer","sourcePageNumber":11}},{"id":"a1058bbc-a429-42f4-8935-d9a5a0e1843d","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":653.4407618323307,"y":780.1027856054451,"width":200,"height":120,"zIndex":1782909267023,"createdAt":1782909267019,"updatedAt":1782909272167,"data":{"type":"note","content":"<p>Note 2 from teacher</p>","color":"green","sourceExcerpt":null,"sourcePageNumber":null,"private":false}},{"id":"ac64cdac-fd4f-48e1-9f4b-1f2eda9cdee4","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":607.6385141566188,"y":639.71904759628,"width":200,"height":120,"zIndex":1782909267026,"createdAt":1782909253229,"updatedAt":1782909334508,"data":{"type":"note","content":"<p>Note 1 from teacher</p><p>Added a note from teacher</p>","color":"red","sourceExcerpt":null,"sourcePageNumber":null,"private":false}},{"id":"b3a8eb1e-bffd-45c3-9e9c-c1a450cd414b","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-380.728875,"y":1930.59646875,"width":602.244,"height":454.912,"zIndex":1777551712560,"createdAt":1777552122875,"updatedAt":1777552172612,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">&nbsp;Change of State &amp; Latent Heat</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Definition:</strong> Heat absorbed or released to change state <em>without any temperature change</em>.</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Q = mL</strong> | Unit: J/kg</p><div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Process</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">For Water</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Latent Heat</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Melting (0°C)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Ice → Water</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">L_f = 3.34 × 10⁵ J/kg</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Boiling (100°C)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Water → Steam</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">L_v = 22.6 × 10⁵ J/kg</td></tr></tbody></table></div><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>L_v &gt;&gt; L_f</strong> — boiling needs ~7× more energy than melting. This is why <strong>steam burns are worse than water burns</strong> at 100°C (extra latent heat released on skin).</p><h4 class=\"text-text-100 mt-2 -mb-1 text-base font-bold\">Heating curve (ice −10°C → steam 100°C):</h4><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Complete calculation for 1 kg:</p><p>\n\n\n\n\n\n\n</p><ul class=\"[li_&amp;]:mb-0 [li_&amp;]:mt-1 [li_&amp;]:gap-1 [&amp;:not(:last-child)_ul]:pb-1 [&amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3\">\n<li class=\"whitespace-normal break-words pl-2\">Heat ice −10°C to 0°C: Q₁ = 1 × 2100 × 10 = <strong>21,000 J</strong></li>\n<li class=\"whitespace-normal break-words pl-2\">Melt ice at 0°C: Q₂ = 1 × 3.34×10⁵ = <strong>334,000 J</strong></li>\n<li class=\"whitespace-normal break-words pl-2\">Heat water 0°C to 100°C: Q₃ = 1 × 4186 × 100 = <strong>418,600 J</strong></li>\n<li class=\"whitespace-normal break-words pl-2\">Boil water at 100°C: Q₄ = 1 × 22.6×10⁵ = <strong>2,260,000 J</strong></li>\n<li class=\"whitespace-normal break-words pl-2\"><strong>Total ≈ 3034 kJ</strong> (boiling dominates!)</li></ul>","color":"#dbeafe","sourceExcerpt":"10.8 Change of State","sourcePageNumber":10}},{"id":"dc797863-07b3-4543-ac17-479f0f82f2b4","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":816.9621783202292,"y":500.33476719741145,"width":200,"height":120,"zIndex":1782910094337,"createdAt":1782910094330,"updatedAt":1782910101790,"data":{"type":"note","content":"<p>Note 3</p>","color":"blue","sourceExcerpt":null,"sourcePageNumber":null,"private":false}},{"id":"ddc69541-9d83-4543-804d-5ecd827c94f5","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-508.838,"y":-174.086,"width":635.012,"height":433.067,"zIndex":1777551712509,"createdAt":1777551739827,"updatedAt":1777551758177,"data":{"type":"note","content":"<p>Heat vs Temperature: A Detailed Comparison\nTo appreciate the difference, consider this analogy: imagine two water tanks at different heights</p><h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Heat vs Temperature</h3>\n<div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Property</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Heat</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Temperature</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">What is it?</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Energy in transit</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Degree of hotness</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">SI Unit</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Joule (J)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Kelvin (K)</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Measured by</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Calorimeter</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Thermometer</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Flows?</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Yes, hot → cold</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Does not flow</td></tr></tbody></table></div>\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Temperature</strong> = measure of average kinetic energy of molecules.\n<strong>Heat</strong> = energy exchanged due to temperature difference. A body does not <em>contain</em> heat — it <em>transfers</em> it.</p>\n<blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Analogy: Temperature = height of water in a tank. Heat = amount of water that flows. A small cup of boiling water has high temperature but <em>less heat</em> than a bathtub of warm water.</p>\n</blockquote>\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Zeroth Law:</strong> If A is in thermal equilibrium with B, and B with C → A is in equilibrium with C. (Basis of thermometers.)</p>","color":"#dbeafe","sourceExcerpt":"Heat vs Temperature: A Detailed Comparison\nTo appreciate the difference, consider this analogy: imagine two water tanks ","sourcePageNumber":2}},{"id":"e5705a75-b697-465d-8ab2-47d0aa5ce4a0","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-368.187,"y":770.214,"width":600.423,"height":621.482,"zIndex":1777551712530,"createdAt":1777551928041,"updatedAt":1777551983983,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Thermal Expansion</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Most solids expand on heating because molecules vibrate more, increasing average spacing.</p><div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Type</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Formula</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Coefficient Relation</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Linear</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">ΔL = αLΔT</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">α</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Area (Superficial)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">ΔA = βAΔT</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">β = 2α</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Volume (Cubical)</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">ΔV = γVΔT</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">γ = 3α</td></tr></tbody></table></div><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>α : β : γ = 1 : 2 : 3</strong> (for isotropic solids)</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">For liquids, only γ is meaningful (no fixed shape).</p><div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Material</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">α (×10⁻⁶/°C)</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Note</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Steel</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">12</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Railway tracks</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Copper</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">17</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Electrical wires</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Glass</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">9</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Pyrex = 3.2 (low)</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Invar</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">0.9</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Clock pendulums</td></tr></tbody></table></div><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Example: Steel rail 10 m at 20°C → at 50°C: ΔL = 12×10⁻⁶ × 10 × 30 = <strong>3.6 mm</strong> (why gaps are left in railway tracks!)</p>\n</blockquote><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Anomalous expansion of water:</strong> Water <em>contracts</em> from 0°C to 4°C → maximum density at 4°C. This is why lakes freeze from the top down (ice floats, bottom water stays at 4°C) — protecting aquatic life.</p><p>\n\n\n\n\n\n\n\n</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Bimetallic strip:</strong> Two metals with different α bonded together → bends on heating → used in thermostats, fire alarms.</p>","color":"#dbeafe","sourceExcerpt":"10.5 Thermal Expansion","sourcePageNumber":6}},{"id":"fc4329b4-0c0c-400e-9299-c5e830774c8d","projectId":"1fca51a6-84b3-46b8-8de7-9e0b79ae50c6","documentId":"b147fb80-76ff-4747-a06d-22cebf231ae7","type":"note","x":-333.042,"y":1452.18,"width":558.553,"height":521.358,"zIndex":1777551712537,"createdAt":1777552007826,"updatedAt":1777552085983,"data":{"type":"note","content":"<h3 class=\"text-text-100 mt-3 -mb-1 text-[1.125rem] font-bold\">Specific Heat Capacity</h3><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Definition:</strong> Heat required to raise temperature of 1 kg of a substance by 1°C (or 1 K).</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\"><strong>Q = mcΔT</strong> | Unit: J/(kg·K)</p><div class=\"overflow-x-auto w-full px-2 mb-6\"><table class=\"min-w-full border-collapse text-sm leading-[1.7] whitespace-normal\"><thead class=\"text-left\"><tr><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Substance</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">c (J/kg·K)</th><th scope=\"col\" class=\"text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold\">Note</th></tr></thead><tbody><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Water</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">4186</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Highest — heats/cools slowly</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Ice</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">2100</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Half of water</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Steam</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">2010</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Half of water</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Aluminium</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">900</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Good for cookware</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Iron/Steel</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">450</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Heats quickly</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Copper</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">390</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Used in calorimeters</td></tr><tr><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Lead</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">130</td><td class=\"border-b-0.5 border-border-300/30 py-2 pr-4 align-top\">Very fast heating</td></tr></tbody></table></div><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">High specific heat of water explains: coastal areas have moderate climate, water used as coolant in car engines, hot water bottles stay warm long.</p><p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">For gases: <strong>Cₚ − Cᵥ = R</strong> (Mayer's relation; Cₚ &gt; Cᵥ because extra work is done against pressure at constant P)</p><p>\n\n\n\n\n\n</p><blockquote class=\"ml-2 border-l-4 border-border-300/10 pl-4 text-text-300\">\n<p class=\"font-claude-response-body break-words whitespace-normal leading-[1.7]\">Example: Heat 2 kg water from 20°C to 100°C → Q = 2 × 4186 × 80 = <strong>670 kJ</strong></p></blockquote>","color":"#dbeafe","sourceExcerpt":"10.6 Specific Heat Capacity","sourcePageNumber":7}}]